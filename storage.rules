rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Members photos
    match /members/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Event images
    match /events/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Form submission uploads
    match /formUploads/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if true; // Public form submissions can upload
    }

    // Wall post images
    match /wallPosts/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Club settings images (president photo, etc.)
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
